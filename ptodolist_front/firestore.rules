rules_version = '2';

// 친구 전용 SNS 모델:
// - users: 모든 인증 사용자 read (친구 닉네임 표시), write 본인만
// - friendCodes: read 모두 (코드 → uid 조회), write 본인 uid 만
// - friendships: read 모두 (친구 검사용), write 멤버만
// - friendRequests/{toUid}/incoming/{fromUid}: 받은 사람만 read, 보낸 사람만 create
// - dailyShares: 본인 또는 친구만 read, 본인만 write

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /friendCodes/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /friendships/{pairId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
                            && request.auth.uid in request.resource.data.members;
      allow delete: if request.auth != null
                    && request.auth.uid in resource.data.members;
    }

    match /friendRequests/{toUid}/incoming/{fromUid} {
      allow read: if request.auth != null && request.auth.uid == toUid;
      allow create: if request.auth != null
                    && request.auth.uid == fromUid
                    && request.resource.data.fromUid == fromUid;
      // 받은 쪽이 수락/거절(=delete), 보낸 쪽이 취소(=delete) 둘 다 허용
      allow delete: if request.auth != null
                    && (request.auth.uid == toUid || request.auth.uid == fromUid);
    }

    match /dailyShares/{shareId} {
      allow read: if request.auth != null && (
        resource.data.uid == request.auth.uid
        || isFriend(resource.data.uid, request.auth.uid)
      );
      allow create, update: if request.auth != null
                            && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.uid == request.auth.uid;
    }

    function isFriend(uidA, uidB) {
      let pairId = uidA < uidB ? uidA + '_' + uidB : uidB + '_' + uidA;
      return exists(/databases/$(database)/documents/friendships/$(pairId));
    }
  }
}
